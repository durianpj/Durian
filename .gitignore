# ──────────────────────────────────────────────
# 환경변수 (API 키, 비밀번호 등 민감 정보)
# ──────────────────────────────────────────────
.env
**/.env

# ──────────────────────────────────────────────
# 원본 인사 데이터 (주민등록번호 등 민감 정보 포함)
# ──────────────────────────────────────────────
data/dataset/*.csv
*.csv
*.jsonl

# ──────────────────────────────────────────────
# 로그 파일 (실행할 때마다 자동 생성)
# ──────────────────────────────────────────────
*.log
data/error.log

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# ──────────────────────────────────────────────
# Node.js
# ──────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*

# ──────────────────────────────────────────────
# 대용량 외부 폴더 (OpenSearch, 모델 파일)
# ──────────────────────────────────────────────
opensearch-3.3.2/
opensearch-dashboards-3.3.0/
models/
*.gguf

# ──────────────────────────────────────────────
# Jupyter 노트북
# ──────────────────────────────────────────────
*.ipynb
.ipynb_checkpoints/

# ──────────────────────────────────────────────
# 문서 파일
# ──────────────────────────────────────────────
*.pdf
*.docx

# ──────────────────────────────────────────────
# 에디터 설정 (개인 환경)
# ──────────────────────────────────────────────
.vscode/
.idea/

# ──────────────────────────────────────────────
# 운영체제 메타파일
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
