# ── OpenSearch 연결 ─────────────────────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=<사용자명>
OPENSEARCH_PASSWORD=<비밀번호>
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false

# OpenSearch 설치 경로 (nori 플러그인 확인에 사용)
OPENSEARCH_HOME=<OpenSearch 설치 경로>

# ── 임베딩 모델 ─────────────────────────────────────────────────────────────────
EMBED_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIMENSION=384
EMBED_BATCH_SIZE=64

# ── KNN 검색 설정 ────────────────────────────────────────────────────────────────
KNN_ENGINE=lucene
KNN_METHOD=hnsw
KNN_SPACE_TYPE=cosinesimil

# ── 청킹 설정 ─────────────────────────────────────────────────────────────────
# 청크당 최대 토큰 수 (모델 max_seq_length 128 - 안전 마진 8)
MAX_TOKENS=120

# ── 경로 설정 ─────────────────────────────────────────────────────────────────
# 필요할 때 주석 해제 후 사용
# INPUT_DIR=<청킹 input 폴더 경로>

# ── 프론트 서버 (server/server.js) ─────────────────────────────────────────────
FRONT_PORT=3000
BACKEND_URL=http://localhost:8000

# ── Ollama (app/main.py) ─────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma3:4b

# ── Hugging Face ─────────────────────────────────────────────────────────────
HF_TOKEN=<Hugging Face 토큰>
